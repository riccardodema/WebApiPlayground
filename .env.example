# Copia questo file in `.env` (gitignored) prima di `docker compose up`.
#
# SQL Server richiede una SA password "forte": almeno 8 caratteri e 3 di queste 4 categorie
# — maiuscole, minuscole, cifre, simboli. Cambiala con la tua.
MSSQL_SA_PASSWORD=Your_strong_Pass123

# Porta host su cui pubblicare il DB (solo per client esterni; l'API usa la rete interna).
# Decommenta/cambia se la 1433 è già occupata da un SQL Server / Azure SQL Edge locale.
#SQL_HOST_PORT=14330
