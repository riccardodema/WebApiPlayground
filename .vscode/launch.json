{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (http)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/WebApiPlayground.Api/bin/Debug/net10.0/WebApiPlayground.Api.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/WebApiPlayground.Api",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5242"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/scalar/v1"
            }
        },
        {
            "name": "Debug (https)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/WebApiPlayground.Api/bin/Debug/net10.0/WebApiPlayground.Api.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/WebApiPlayground.Api",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:7123;http://localhost:5242"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/scalar/v1"
            }
        }
    ]
}
