{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/src/WebApiPlayground.Api/WebApiPlayground.Api.csproj",
                "--configuration",
                "Debug"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "test",
            "command": "dotnet",
            "type": "process",
            "args": [
                "test",
                "${workspaceFolder}/tests/WebApiPlayground.Tests/WebApiPlayground.Tests.csproj",
                "--verbosity",
                "normal"
            ],
            "problemMatcher": "$msCompile",
            "group": "test"
        }
    ]
}
