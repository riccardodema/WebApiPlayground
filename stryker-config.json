{
  "stryker-config": {
    "coverage-analysis": "perTest",
    "mutate": [
      "**/*.cs",
      "!**/*.generated.cs",
      "!**/Extensions/ApiVersioningExtensions.cs"
    ],
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 15
    },
    "ignore-methods": [
      "*Log*",
      "LoggerExtensions.*"
    ]
  }
}